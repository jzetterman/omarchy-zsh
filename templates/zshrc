# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Set the base directory for legendary-zsh
export LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"

# Load zsh options, keybindings, and completion
source "$LEGENDARY_ZSH_HOME/shell/zoptions"

# Load zsh plugins (syntax highlighting, autosuggestions, completions, fzf-tab)
source "$LEGENDARY_ZSH_HOME/shell/plugins"

# Initialize completion system (after plugins so zsh-completions fpath is available)
autoload -U compinit && compinit

# Load tmux functions and alias
source "$LEGENDARY_ZSH_HOME/shell/tmux"

# Load shared shell configuration (aliases, functions, environment, tool init)
source "$LEGENDARY_ZSH_HOME/shell/all"

