# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# Set the base directory for legendary-zsh
export LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"

# Load zsh options, keybindings, and completion
source "$LEGENDARY_ZSH_HOME/shell/zoptions"

# Load zsh plugins (syntax highlighting, autosuggestions, completions, fzf-tab)
source "$LEGENDARY_ZSH_HOME/shell/plugins"

# Initialize completion system (after plugins so zsh-completions fpath is
# available). Cache the dump in ~/.cache/zsh and skip the slow insecure-files
# check when the cache is less than a day old. Saves ~100-200ms per shell
# start once the cache is warm.
autoload -Uz compinit
_zcompdump="$HOME/.cache/zsh/zcompdump"
[[ -d "${_zcompdump:h}" ]] || mkdir -p "${_zcompdump:h}"
if [[ -n "$_zcompdump"(#qNmh-24) ]]; then
  compinit -C -d "$_zcompdump"
else
  compinit -d "$_zcompdump"
fi
unset _zcompdump

# Load tmux functions and alias
source "$LEGENDARY_ZSH_HOME/shell/tmux"

# Load shared shell configuration (aliases, functions, environment, tool init)
source "$LEGENDARY_ZSH_HOME/shell/all"

# Source user-local config (survives reinstalls and template redeployment)
[[ -f "$HOME/.config/legendary-zsh/local.zsh" ]] && source "$HOME/.config/legendary-zsh/local.zsh"

# Add your own customizations below this line — they will be preserved across
# legendary-zsh updates. For config that should never be touched by the
# framework, use ~/.config/legendary-zsh/local.zsh instead.
