#!/bin/bash

case "${1:-}" in
  -h|--help)
    cat <<EOF
Usage: legendary-update

Updates legendary-zsh to the latest version. Pulls the latest commits
(fast-forward only), runs any pending migrations, installs any newly
added dependencies, and re-offers chsh and fastfetch if those prompts
haven't been answered yet.

Environment (non-interactive mode):
  LEGENDARY_NONINTERACTIVE=1        Skip prompts; preservation-safe defaults
  LEGENDARY_CHSH=yes                Change default login shell to zsh
  LEGENDARY_FASTFETCH=yes           Install fastfetch and enable on new shells
  LEGENDARY_MIGRATE_APPLY=yes       Apply user-dotfile migrations without prompting
EOF
    exit 0
    ;;
esac

LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"

# Prompt the user y/N. Returns 0 (yes) / 1 (no). When LEGENDARY_NONINTERACTIVE
# is set, reads $1 as the override value — y/Y/yes/YES/1/true/TRUE counts as
# yes; anything else (including empty) counts as no. Otherwise prompts via
# gum when available, with a (y/N) read fallback.
_lz_confirm() {
  if [ -n "$LEGENDARY_NONINTERACTIVE" ]; then
    case "$1" in
      y|Y|yes|YES|1|true|TRUE) return 0 ;;
      *) return 1 ;;
    esac
  fi
  if command -v gum &>/dev/null; then
    gum confirm ""
  else
    printf "(y/N) "
    read -r reply
    [[ "$reply" =~ ^[Yy] ]]
  fi
}

echo "Updating legendary-zsh..."

# Pull latest changes
git -C "$LEGENDARY_ZSH_HOME" pull --ff-only || { echo "Error: git pull failed"; exit 1; }

# Run any pending migrations
"$LEGENDARY_ZSH_HOME/bin/legendary-migrate"

# Install any new dependencies
"$LEGENDARY_ZSH_HOME/bin/legendary-install-deps"

# Offer to switch default shell to zsh (only asks once)
STATE_DIR="${HOME}/.local/state/legendary-zsh"
mkdir -p "$STATE_DIR"
_shell_changed=false

if [ ! -f "$STATE_DIR/chsh-prompted" ]; then
  ZSH_PATH="$(command -v zsh 2>/dev/null)"
  if [ -n "$ZSH_PATH" ]; then
    if [ "$(basename "$SHELL")" != "zsh" ]; then
      echo ""
      echo "Would you like to set zsh as your default shell?"
      if _lz_confirm "$LEGENDARY_CHSH"; then
        if chsh -s "$ZSH_PATH" || sudo chsh -s "$ZSH_PATH" "$USER"; then
          echo -e "\033[32m✓ Default shell changed to zsh\033[0m"
          _shell_changed=true
        else
          echo "Warning: chsh failed. You may need to run: sudo chsh -s $ZSH_PATH \$USER"
        fi
      fi
    fi
    touch "$STATE_DIR/chsh-prompted"
  fi
fi

# Offer to install fastfetch (only asks once)
ZSHRC="${HOME}/.zshrc"

if [ ! -f "$STATE_DIR/fastfetch-prompted" ] && ! grep -qF 'fastfetch' "$ZSHRC" 2>/dev/null; then
  echo ""
  echo "Would you like to install fastfetch and run it when new terminal sessions start?"
  if _lz_confirm "$LEGENDARY_FASTFETCH"; then
    if ! command -v fastfetch &>/dev/null; then
      echo "Installing fastfetch..."
      if [[ "$OSTYPE" == darwin* ]]; then
        brew install fastfetch
      elif command -v pacman &>/dev/null; then
        sudo pacman -S --needed --noconfirm fastfetch
      elif command -v apt-get &>/dev/null; then
        sudo apt-get install -y fastfetch
      elif command -v dnf &>/dev/null; then
        sudo dnf install -y fastfetch
      fi
    fi
    if ! grep -qF 'fastfetch' "$ZSHRC"; then
      printf '\n# legendary-zsh:fastfetch-start\ncommand -v fastfetch &>/dev/null && fastfetch\n# legendary-zsh:fastfetch-end\n' >> "$ZSHRC"
    fi
    echo -e "\033[32m✓ fastfetch enabled\033[0m"
  fi
  touch "$STATE_DIR/fastfetch-prompted"
fi

echo ""
echo -e "\033[32m✓ legendary-zsh updated\033[0m"
if [ "$_shell_changed" = true ]; then
  echo "Log out and back in to start using zsh."
else
  echo "Restart your terminal to pick up changes."
fi
