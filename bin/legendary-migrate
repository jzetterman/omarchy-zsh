#!/bin/bash
set -e

case "${1:-}" in
  -h|--help)
    cat <<EOF
Usage: legendary-migrate

Runs any pending migrations from migrations/*.sh. Each migration runs
at most once — successful runs are tracked by marker files in
~/.local/state/legendary-zsh/migrations/.

Migrations that modify user dotfiles prompt before applying.

Environment:
  LEGENDARY_NONINTERACTIVE=1        Skip prompts
  LEGENDARY_MIGRATE_APPLY=yes       Apply user-dotfile migrations without
                                    prompting (default in non-interactive
                                    mode: decline)
EOF
    exit 0
    ;;
esac

LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"
STATE_DIR="${HOME}/.local/state/legendary-zsh/migrations"
MIGRATIONS_DIR="${LEGENDARY_ZSH_HOME}/migrations"

mkdir -p "$STATE_DIR"

for file in "$MIGRATIONS_DIR"/*.sh; do
  [ -f "$file" ] || continue
  filename=$(basename "$file")

  if [[ ! -f "$STATE_DIR/$filename" ]]; then
    echo "Running migration: ${filename%.sh}"

    if bash "$file"; then
      touch "$STATE_DIR/$filename"
    else
      echo ""
      echo "Migration failed: $filename"
      read -p "Skip and continue? [y/N] " choice
      if [[ "$choice" =~ ^[Yy]$ ]]; then
        touch "$STATE_DIR/$filename"
      else
        exit 1
      fi
    fi
  fi
done
