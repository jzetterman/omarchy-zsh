#!/bin/bash

LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"
PLUGINS_DIR="${LEGENDARY_ZSH_HOME}/plugins"
ZSHRC="${HOME}/.zshrc"
ZSHRC_TEMPLATE="${LEGENDARY_ZSH_HOME}/templates/zshrc"
INPUTRC_SRC="${LEGENDARY_ZSH_HOME}/shell/inputrc"
STARSHIP_TEMPLATE="${LEGENDARY_ZSH_HOME}/templates/starship"
STARSHIP_CONFIG="${HOME}/.config/starship.toml"
ZSHRC_BACKUP="${HOME}/.zshrc.backup-$(date +%Y%m%d-%H%M%S)"
STARSHIP_BACKUP="${HOME}/.config/starship.toml.backup-$(date +%Y%m%d-%H%M%S)"

# Prompt the user y/N. Returns 0 (yes) / 1 (no). When LEGENDARY_NONINTERACTIVE
# is set, reads $1 as the override value — y/Y/yes/YES/1/true/TRUE counts as
# yes; anything else (including empty) counts as no. Otherwise prompts via
# gum when available, with a (y/N) read fallback.
_lz_confirm() {
  if [ -n "$LEGENDARY_NONINTERACTIVE" ]; then
    case "$1" in
      y|Y|yes|YES|1|true|TRUE) return 0 ;;
      *) return 1 ;;
    esac
  fi
  if command -v gum &>/dev/null; then
    gum confirm ""
  else
    printf "(y/N) "
    read -r reply
    [[ "$reply" =~ ^[Yy] ]]
  fi
}

echo "Setting up legendary-zsh..."

# Install zsh plugins via git clone
mkdir -p "${PLUGINS_DIR}"

clone_plugin() {
  local name="$1" repo="$2"
  if [ -d "${PLUGINS_DIR}/${name}" ]; then
    echo "  - ${name} (already installed)"
  else
    echo "  - ${name} (cloning...)"
    git clone --depth 1 "https://github.com/${repo}.git" "${PLUGINS_DIR}/${name}" >/dev/null 2>&1
  fi
}

echo "Installing zsh plugins..."
clone_plugin "zsh-syntax-highlighting" "zsh-users/zsh-syntax-highlighting"
clone_plugin "zsh-autosuggestions"     "zsh-users/zsh-autosuggestions"
clone_plugin "zsh-completions"         "zsh-users/zsh-completions"
clone_plugin "fzf-tab"                 "Aloxaf/fzf-tab"

# Install .zshrc (preserving user customizations below the marker comment)
CUSTOMIZATION_MARKER="# Add your own customizations below"
USER_CUSTOMIZATIONS=""
if [ -f "${ZSHRC}" ]; then
  cp "${ZSHRC}" "${ZSHRC_BACKUP}"
  # Extract everything after the customization marker from the OLD zshrc
  USER_CUSTOMIZATIONS="$(sed -n "/${CUSTOMIZATION_MARKER}/,\$p" "${ZSHRC}" | tail -n +2)"
fi
cp "${ZSHRC_TEMPLATE}" "${ZSHRC}"
# Re-append user customizations if any were found
if [ -n "${USER_CUSTOMIZATIONS}" ]; then
  printf '\n%s\n' "${USER_CUSTOMIZATIONS}" >> "${ZSHRC}"
fi

# Install inputrc (bash reads ~/.inputrc directly; zsh does not read it).
# Skip if the user already has one so we don't clobber their readline config.
if [ ! -f "${HOME}/.inputrc" ]; then
  cp "${INPUTRC_SRC}" "${HOME}/.inputrc"
fi

# Install starship config. If the user has one already, prompt before replacing.
mkdir -p "${HOME}/.config"
STATE_DIR="${HOME}/.local/state/legendary-zsh"
mkdir -p "$STATE_DIR"
STARSHIP_PROMPTED_MARKER="$STATE_DIR/starship-prompted"
if [ ! -f "${STARSHIP_CONFIG}" ]; then
  cp "${STARSHIP_TEMPLATE}" "${STARSHIP_CONFIG}"
elif [ ! -f "$STARSHIP_PROMPTED_MARKER" ]; then
  echo ""
  echo "You have an existing ~/.config/starship.toml."
  echo "Replace it with legendary-zsh's config? Your current config will be backed up."
  if _lz_confirm "$LEGENDARY_STARSHIP_REPLACE"; then
    cp "${STARSHIP_CONFIG}" "${STARSHIP_BACKUP}"
    cp "${STARSHIP_TEMPLATE}" "${STARSHIP_CONFIG}"
  fi
  touch "$STARSHIP_PROMPTED_MARKER"
fi

# Mark all current migrations as already run (fresh install needs none)
MIGRATIONS_STATE="${HOME}/.local/state/legendary-zsh/migrations"
mkdir -p "$MIGRATIONS_STATE"
for file in "$LEGENDARY_ZSH_HOME"/migrations/*.sh; do
  [ -f "$file" ] && touch "$MIGRATIONS_STATE/$(basename "$file")"
done

# Record the user's original shell for uninstall
echo "$SHELL" > "${HOME}/.local/state/legendary-zsh/original-shell"

echo ""
echo -e "\033[32m✓ legendary-zsh setup complete\033[0m"
if [ -f "${ZSHRC_BACKUP}" ]; then
  echo "  - Original .zshrc backed up to:"
  echo "    ${ZSHRC_BACKUP}"
fi
if [ -f "${STARSHIP_BACKUP}" ]; then
  echo "  - Original starship.toml backed up to:"
  echo "    ${STARSHIP_BACKUP}"
fi

# Offer to switch default shell to zsh (only asks once)
_shell_changed=false

if [ ! -f "$STATE_DIR/chsh-prompted" ]; then
  ZSH_PATH="$(command -v zsh 2>/dev/null)"
  if [ -n "$ZSH_PATH" ]; then
    if [ "$(basename "$SHELL")" != "zsh" ]; then
      echo ""
      echo "Would you like to set zsh as your default shell?"
      if _lz_confirm "$LEGENDARY_CHSH"; then
        if chsh -s "$ZSH_PATH" || sudo chsh -s "$ZSH_PATH" "$USER"; then
          echo -e "\033[32m✓ Default shell changed to zsh\033[0m"
          _shell_changed=true
        else
          echo "Warning: chsh failed. You may need to run: sudo chsh -s $ZSH_PATH \$USER"
        fi
      fi
    fi
    touch "$STATE_DIR/chsh-prompted"
  fi
fi

# Offer to install fastfetch
if [ ! -f "$STATE_DIR/fastfetch-prompted" ] && ! grep -qF 'fastfetch' "$ZSHRC" 2>/dev/null; then
  echo ""
  echo "Would you like to install fastfetch and run it when new terminal sessions start?"
  if _lz_confirm "$LEGENDARY_FASTFETCH"; then
    if ! command -v fastfetch &>/dev/null; then
      echo "Installing fastfetch..."
      if [[ "$OSTYPE" == darwin* ]]; then
        brew install fastfetch
      elif command -v pacman &>/dev/null; then
        sudo pacman -S --needed --noconfirm fastfetch
      elif command -v apt-get &>/dev/null; then
        sudo apt-get install -y fastfetch
      elif command -v dnf &>/dev/null; then
        sudo dnf install -y fastfetch
      fi
    fi
    if ! grep -qF 'fastfetch' "$ZSHRC"; then
      printf '\n# legendary-zsh:fastfetch-start\ncommand -v fastfetch &>/dev/null && fastfetch\n# legendary-zsh:fastfetch-end\n' >> "$ZSHRC"
    fi
    echo -e "\033[32m✓ fastfetch enabled\033[0m"
  fi
  touch "$STATE_DIR/fastfetch-prompted"
fi

echo ""
if [ "$_shell_changed" = true ]; then
  echo "Log out and back in to start using zsh."
else
  echo "Open a new terminal to get started."
fi
echo ""
echo "To update later, run: legendary-update"
echo "To uninstall, run: legendary-uninstall"
