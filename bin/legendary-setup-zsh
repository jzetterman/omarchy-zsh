#!/bin/bash

LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"
PLUGINS_DIR="${LEGENDARY_ZSH_HOME}/plugins"
ZSHRC="${HOME}/.zshrc"
BASHRC="${HOME}/.bashrc"
ZSHRC_TEMPLATE="${LEGENDARY_ZSH_HOME}/templates/zshrc"
BASHRC_TEMPLATE="${LEGENDARY_ZSH_HOME}/templates/bashrc"
INPUTRC_SRC="${LEGENDARY_ZSH_HOME}/shell/inputrc"
ZSHRC_BACKUP="${HOME}/.zshrc.backup-$(date +%Y%m%d-%H%M%S)"
BASHRC_BACKUP="${HOME}/.bashrc.backup-$(date +%Y%m%d-%H%M%S)"

echo "Setting up legendary-zsh..."

# Install zsh plugins via git clone
mkdir -p "${PLUGINS_DIR}"

clone_plugin() {
  local name="$1" repo="$2"
  if [ -d "${PLUGINS_DIR}/${name}" ]; then
    echo "  - ${name} (already installed)"
  else
    echo "  - ${name} (cloning...)"
    git clone --depth 1 "https://github.com/${repo}.git" "${PLUGINS_DIR}/${name}" >/dev/null 2>&1
  fi
}

echo "Installing zsh plugins..."
clone_plugin "zsh-syntax-highlighting" "zsh-users/zsh-syntax-highlighting"
clone_plugin "zsh-autosuggestions"     "zsh-users/zsh-autosuggestions"
clone_plugin "zsh-completions"         "zsh-users/zsh-completions"
clone_plugin "fzf-tab"                 "Aloxaf/fzf-tab"

# Install .zshrc
if [ -f "${ZSHRC}" ]; then
  cp "${ZSHRC}" "${ZSHRC_BACKUP}"
fi
cp "${ZSHRC_TEMPLATE}" "${ZSHRC}"

# Install bash auto-launch
if [ -f "${BASHRC}" ]; then
  cp "${BASHRC}" "${BASHRC_BACKUP}"
fi
cp "${BASHRC_TEMPLATE}" "${BASHRC}"

# Install inputrc (bash reads ~/.inputrc directly)
cp -f "${INPUTRC_SRC}" "${HOME}/.inputrc"

# Mark all current migrations as already run (fresh install needs none)
MIGRATIONS_STATE="${HOME}/.local/state/legendary-zsh/migrations"
mkdir -p "$MIGRATIONS_STATE"
for file in "$LEGENDARY_ZSH_HOME"/migrations/*.sh; do
  [ -f "$file" ] && touch "$MIGRATIONS_STATE/$(basename "$file")"
done

echo ""
echo -e "\033[32m✓ legendary-zsh setup complete\033[0m"
if [ -f "${ZSHRC_BACKUP}" ]; then
  echo "  - Original .zshrc backed up to:"
  echo "    ${ZSHRC_BACKUP}"
  echo ""
fi
if [ -f "${BASHRC_BACKUP}" ]; then
  echo "  - Original .bashrc backed up to:"
  echo "    ${BASHRC_BACKUP}"
  echo ""
fi
echo "Restart your terminal to activate zsh"

# Offer to switch default shell to zsh (only asks once)
STATE_DIR="${HOME}/.local/state/legendary-zsh"
mkdir -p "$STATE_DIR"

if [ ! -f "$STATE_DIR/chsh-prompted" ]; then
  ZSH_PATH="$(command -v zsh 2>/dev/null)"
  if [ -n "$ZSH_PATH" ]; then
    if [ "$(basename "$SHELL")" != "zsh" ]; then
      echo ""
      echo "Would you like to set zsh as your default shell?"
      wants_chsh=false
      if command -v gum &>/dev/null; then
        gum confirm "" && wants_chsh=true || true
      else
        printf "(y/N) "
        read -r reply
        [[ "$reply" =~ ^[Yy] ]] && wants_chsh=true
      fi
      if [ "$wants_chsh" = true ]; then
        if chsh -s "$ZSH_PATH" 2>/dev/null; then
          echo -e "\033[32m✓ Default shell changed to zsh\033[0m"
          echo "  This will take effect on your next login."
        else
          echo "Warning: chsh failed. You may need to run: sudo chsh -s $ZSH_PATH \$USER"
        fi
      fi
    fi
    touch "$STATE_DIR/chsh-prompted"
  fi
fi

# Offer to install fastfetch
if [ ! -f "$STATE_DIR/fastfetch-prompted" ] && ! grep -qF 'fastfetch' "$ZSHRC" 2>/dev/null; then
  echo ""
  echo "Would you like to install fastfetch and run it when new terminal sessions start?"
  wants_fastfetch=false
  if command -v gum &>/dev/null; then
    gum confirm "" && wants_fastfetch=true || true
  fi
  if [ "$wants_fastfetch" = true ]; then
    if ! command -v fastfetch &>/dev/null; then
      echo "Installing fastfetch..."
      if [[ "$OSTYPE" == darwin* ]]; then
        brew install fastfetch
      elif command -v pacman &>/dev/null; then
        sudo pacman -S --needed --noconfirm fastfetch
      elif command -v apt-get &>/dev/null; then
        sudo apt-get install -y fastfetch
      elif command -v dnf &>/dev/null; then
        sudo dnf install -y fastfetch
      fi
    fi
    if ! grep -qF 'fastfetch' "$ZSHRC"; then
      printf '\n# Show system info on new terminal sessions\ncommand -v fastfetch &>/dev/null && fastfetch\n' >> "$ZSHRC"
    fi
    echo -e "\033[32m✓ fastfetch enabled\033[0m"
  fi
  touch "$STATE_DIR/fastfetch-prompted"
fi
