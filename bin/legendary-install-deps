#!/bin/bash

missing=()

for cmd in git zsh fzf starship zoxide eza gum; do
  command -v "$cmd" &>/dev/null || missing+=("$cmd")
done

if [ ${#missing[@]} -eq 0 ]; then
  return 0 2>/dev/null || exit 0
fi

echo "Installing missing dependencies: ${missing[*]}"

if [[ "$OSTYPE" == darwin* ]]; then
  if ! command -v brew &>/dev/null; then
    echo "Error: Homebrew is required on macOS. Install it from https://brew.sh"
    exit 1
  fi
  brew install "${missing[@]}"

elif command -v pacman &>/dev/null; then
  sudo pacman -S --needed --noconfirm "${missing[@]}"

elif command -v apt-get &>/dev/null; then
  apt_pkgs=()
  manual_pkgs=()

  for pkg in "${missing[@]}"; do
    case "$pkg" in
      starship|zoxide|eza|gum) manual_pkgs+=("$pkg") ;;
      *) apt_pkgs+=("$pkg") ;;
    esac
  done

  if [ ${#apt_pkgs[@]} -gt 0 ]; then
    sudo apt-get update -qq
    sudo apt-get install -y "${apt_pkgs[@]}"
  fi

  for pkg in "${manual_pkgs[@]}"; do
    case "$pkg" in
      starship)
        echo "Installing starship..."
        curl -sS https://starship.rs/install.sh | sh -s -- -y
        ;;
      zoxide)
        echo "Installing zoxide..."
        curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
        ;;
      eza)
        echo "Installing eza..."
        sudo mkdir -p /etc/apt/keyrings
        wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
        echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list >/dev/null
        sudo apt-get update -qq
        sudo apt-get install -y eza
        ;;
      gum)
        echo "Installing gum..."
        sudo mkdir -p /etc/apt/keyrings
        curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg
        echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null
        sudo apt-get update -qq
        sudo apt-get install -y gum
        ;;
    esac
  done

elif command -v dnf &>/dev/null; then
  dnf_pkgs=()
  manual_pkgs=()

  for pkg in "${missing[@]}"; do
    case "$pkg" in
      starship|eza|gum) manual_pkgs+=("$pkg") ;;
      *) dnf_pkgs+=("$pkg") ;;
    esac
  done

  if [ ${#dnf_pkgs[@]} -gt 0 ]; then
    sudo dnf install -y "${dnf_pkgs[@]}"
  fi

  for pkg in "${manual_pkgs[@]}"; do
    case "$pkg" in
      starship)
        echo "Installing starship..."
        curl -sS https://starship.rs/install.sh | sh -s -- -y
        ;;
      eza)
        echo "Installing eza..."
        _arch="$(uname -m)"
        if [ "$_arch" = "x86_64" ] || [ "$_arch" = "aarch64" ]; then
          sudo mkdir -p /usr/local/bin
          _tmpfile="$(mktemp)"
          if curl -sSfL "https://github.com/eza-community/eza/releases/latest/download/eza_${_arch}-unknown-linux-gnu.tar.gz" -o "$_tmpfile"; then
            sudo tar xzf "$_tmpfile" -C /usr/local/bin/
            sudo chmod +x /usr/local/bin/eza
          else
            echo "Warning: could not download eza. Skipping."
          fi
          rm -f "$_tmpfile"
        else
          echo "Warning: could not install eza for architecture $_arch. Skipping."
        fi
        ;;
      gum)
        echo "Installing gum..."
        echo '[charm]
name=Charm
baseurl=https://repo.charm.sh/yum/
enabled=1
gpgcheck=1
gpgkey=https://repo.charm.sh/yum/gpg.key' | sudo tee /etc/yum.repos.d/charm.repo >/dev/null
        sudo dnf install -y gum
        ;;
    esac
  done

else
  echo "Warning: Could not detect package manager. Install these manually: ${missing[*]}"
fi
