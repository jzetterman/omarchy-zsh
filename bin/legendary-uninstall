#!/bin/bash

LEGENDARY_ZSH_HOME="${HOME}/.local/share/legendary-zsh"
STATE_DIR="${HOME}/.local/state/legendary-zsh"

echo "This will remove legendary-zsh and its configuration."
echo ""
wants_uninstall=false
if command -v gum &>/dev/null; then
  gum confirm "Uninstall legendary-zsh?" && wants_uninstall=true || true
else
  printf "Uninstall legendary-zsh? (y/N) "
  read -r reply
  [[ "$reply" =~ ^[Yy] ]] && wants_uninstall=true
fi

if [ "$wants_uninstall" != true ]; then
  echo "Uninstall cancelled."
  exit 0
fi

# Switch shell back to bash before removing config files
_shell_changed=false
BASH_PATH="$(command -v bash 2>/dev/null)"
if [ -n "$BASH_PATH" ] && [ "$(basename "$SHELL")" = "zsh" ]; then
  echo ""
  echo "Your default shell is zsh. Switch back to bash?"
  wants_bash=false
  if command -v gum &>/dev/null; then
    gum confirm "" && wants_bash=true || true
  else
    printf "(y/N) "
    read -r reply
    [[ "$reply" =~ ^[Yy] ]] && wants_bash=true
  fi
  if [ "$wants_bash" = true ]; then
    if chsh -s "$BASH_PATH" || sudo chsh -s "$BASH_PATH" "$USER"; then
      echo -e "  \033[32m✓\033[0m Default shell changed to bash"
      _shell_changed=true
    else
      echo "  Warning: chsh failed. Run: sudo chsh -s $BASH_PATH \$USER"
    fi
  fi
fi

# Restore or remove dotfiles
for dotfile in .zshrc .bashrc; do
  current="${HOME}/${dotfile}"
  [ -f "$current" ] || continue
  latest_backup="$(ls -t "${HOME}/${dotfile}.backup-"* 2>/dev/null | head -1)"
  if [ -n "$latest_backup" ]; then
    echo ""
    echo "Restore ${dotfile} from backup? (${latest_backup})"
    wants_restore=false
    if command -v gum &>/dev/null; then
      gum confirm "" && wants_restore=true || true
    else
      printf "(y/N) "
      read -r reply
      [[ "$reply" =~ ^[Yy] ]] && wants_restore=true
    fi
    if [ "$wants_restore" = true ]; then
      cp "$latest_backup" "$current"
      echo -e "  \033[32m✓\033[0m Restored ${dotfile}"
    else
      rm -f "$current"
      echo "  Removed ${dotfile}"
    fi
  else
    rm -f "$current"
    echo "  Removed ${dotfile}"
  fi
done

rm -f "${HOME}/.inputrc"

# Remove legendary-zsh directories
rm -rf "$LEGENDARY_ZSH_HOME"
rm -rf "$STATE_DIR"

echo ""
echo -e "\033[32m✓ legendary-zsh uninstalled\033[0m"
if [ "$_shell_changed" = true ]; then
  echo "Log out and back in to return to bash."
fi
