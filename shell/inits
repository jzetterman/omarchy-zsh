_shell_name="${ZSH_VERSION:+zsh}"
_shell_name="${_shell_name:-bash}"

if command -v mise &>/dev/null; then
  eval "$(mise activate "$_shell_name")"
fi

if command -v starship &>/dev/null; then
  if [[ "$_shell_name" == "bash" ]]; then
    # clear stale readline state before rendering prompt (prevents artifacts in prompt after abnormal exits like SIGQUIT)
    __sanitize_prompt() { printf '\r\033[K'; }
    PROMPT_COMMAND="__sanitize_prompt${PROMPT_COMMAND:+;$PROMPT_COMMAND}"
  fi
  eval "$(starship init "$_shell_name")"
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init "$_shell_name")"
fi

if command -v try &>/dev/null; then
  eval "$(try init ~/Work/tries)"
fi

if command -v fzf &>/dev/null; then
  # Detect Homebrew prefix for macOS
  _brew_prefix="${HOMEBREW_PREFIX:-$(command -v brew &>/dev/null && brew --prefix)}"

  if [[ "$_shell_name" == "bash" ]]; then
    for f in /usr/share/fzf/completion.bash /usr/share/bash-completion/completions/fzf /usr/share/doc/fzf/examples/completion.bash ${_brew_prefix:+$_brew_prefix/opt/fzf/shell/completion.bash}; do
      [[ -f $f ]] && source "$f" && break
    done
    for f in /usr/share/fzf/key-bindings.bash /usr/share/doc/fzf/examples/key-bindings.bash ${_brew_prefix:+$_brew_prefix/opt/fzf/shell/key-bindings.bash}; do
      [[ -f $f ]] && source "$f" && break
    done
  elif [[ "$_shell_name" == "zsh" ]]; then
    for f in /usr/share/fzf/completion.zsh /usr/share/doc/fzf/examples/completion.zsh ${_brew_prefix:+$_brew_prefix/opt/fzf/shell/completion.zsh}; do
      [[ -f $f ]] && source "$f" && break
    done
    for f in /usr/share/fzf/key-bindings.zsh /usr/share/doc/fzf/examples/key-bindings.zsh ${_brew_prefix:+$_brew_prefix/opt/fzf/shell/key-bindings.zsh}; do
      [[ -f $f ]] && source "$f" && break
    done
  fi

  unset _brew_prefix
fi

unset _shell_name
