# Zsh plugins sourced from system packages and local clones

# Syntax highlighting (colors commands as you type)
if [[ -f /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]]; then
  source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
fi

# Autosuggestions (faint history suggestions as you type, accept with right-arrow)
if [[ -f /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh
fi

# fzf-tab (replace completion menu with fzf)
FZF_TAB_HOME="${HOME}/.local/share/omarchy-zsh/fzf-tab"
if [[ -f "${FZF_TAB_HOME}/fzf-tab.plugin.zsh" ]]; then
  source "${FZF_TAB_HOME}/fzf-tab.plugin.zsh"
  zstyle ':fzf-tab:complete:cd:*' fzf-preview 'ls --color $realpath'
  zstyle ':completion:*' menu no
fi
