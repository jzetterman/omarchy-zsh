# Eza (https://eza.rocks/)
if command -v eza &>/dev/null; then
  alias ls='eza -lh --group-directories-first --icons=auto'
  alias lsa='ls -a'
fi

# Fuzzy find (https://junegunn.github.io/fzf/)
alias ff="fzf --preview 'bat --style=numbers --color=always {}'"
alias eff='$EDITOR $(ff)'

# Smart cd (https://github.com/ajeetdsouza/zoxide)
if command -v zoxide &>/dev/null; then
  alias cd="zd"
  zd() {
    if [[ $# -eq 0 ]]; then
      builtin cd ~ && return
    elif [[ -d $1 ]]; then
      builtin cd "$1"
    else
      z "$@" && printf "%s " "->" && pwd || echo "Error: Directory not found"
    fi
  }
fi

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Tools
alias c='opencode'
alias cx='printf "\033[2J\033[3J\033[H" && claude --permission-mode=plan --allow-dangerously-skip-permissions'
alias d='docker'
alias lzd='lazydocker'
alias r='rails'
alias v='vim'
n() { if [[ $# -eq 0 ]]; then nvim .; else nvim "$@"; fi; }

# Git
alias g='git'
alias gcm='git commit -m'
alias gcam='git commit -a -m'
